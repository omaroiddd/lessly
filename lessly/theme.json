{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"defaultDuotone": false,
			"palette": [
				{
					"slug": "base",
					"color": "#FFFFFF",
					"name": "Base"
				},
				{
					"slug": "contrast",
					"color": "#0F172A",
					"name": "Contrast"
				},
				{
					"slug": "primary",
					"color": "#2563EB",
					"name": "Primary"
				},
				{
					"slug": "secondary",
					"color": "#64748B",
					"name": "Secondary"
				},
				{
					"slug": "tertiary",
					"color": "#F1F5F9",
					"name": "Tertiary"
				}
			]
		},
		"typography": {
			"fluid": true,
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"slug": "inter",
					"name": "Inter",
					"fontFamily": "\"Inter\", ui-sans-serif, system-ui, sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\", \"Segoe UI Symbol\", \"Noto Color Emoji\"",
					"fontFace": [
						{
							"fontFamily": "Inter",
							"fontStyle": "normal",
							"fontWeight": "100 900",
							"fontStretch": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/InterVariable.woff2" ]
						},
						{
							"fontFamily": "Inter",
							"fontStyle": "italic",
							"fontWeight": "100 900",
							"fontStretch": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/InterVariable-Italic.woff2" ]
						}
					]
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"name": "Small",
					"size": "0.875rem",
					"fluid": {
						"min": "0.8125rem",
						"max": "0.9375rem"
					}
				},
				{
					"slug": "medium",
					"name": "Medium",
					"size": "1rem",
					"fluid": {
						"min": "1rem",
						"max": "1.125rem"
					}
				},
				{
					"slug": "large",
					"name": "Large",
					"size": "1.25rem",
					"fluid": {
						"min": "1.125rem",
						"max": "1.375rem"
					}
				},
				{
					"slug": "x-large",
					"name": "Extra Large",
					"size": "1.75rem",
					"fluid": {
						"min": "1.5rem",
						"max": "2.125rem"
					}
				},
				{
					"slug": "xx-large",
					"name": "Extra Extra Large",
					"size": "2.5rem",
					"fluid": {
						"min": "2rem",
						"max": "3.5rem"
					}
				}
			]
		},
		"layout": {
			"contentSize": "768px",
			"wideSize": "1280px"
		},
		"spacing": {
			"units": [ "px", "em", "rem", "%", "vh", "vw" ],
			"spacingSizes": [
				{
					"slug": "20",
					"name": "1",
					"size": "0.25rem"
				},
				{
					"slug": "30",
					"name": "2",
					"size": "0.5rem"
				},
				{
					"slug": "40",
					"name": "3",
					"size": "1rem"
				},
				{
					"slug": "50",
					"name": "4",
					"size": "1.5rem"
				},
				{
					"slug": "60",
					"name": "5",
					"size": "2.5rem"
				},
				{
					"slug": "70",
					"name": "6",
					"size": "4rem"
				},
				{
					"slug": "80",
					"name": "7",
					"size": "6rem"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--inter)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.6"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				":hover": {
					"typography": {
						"textDecoration": "underline"
					}
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--inter)",
					"lineHeight": "1.2"
				}
			}
		}
	}
}
