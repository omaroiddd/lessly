{
	"require-dev": {
		"dealerdirect/phpcodesniffer-composer-installer": "^1.1",
		"phpcompatibility/phpcompatibility-wp": "^2.1",
		"sirbrillig/phpcs-changed": "^2.11",
		"sirbrillig/phpcs-variable-analysis": "^2.12",
		"wp-cli/i18n-command": "^2.6",
		"wp-coding-standards/wpcs": "^3.2",
		"phpunit/phpunit": "^10.5",
		"brain/monkey": "^2.6",
		"mockery/mockery": "^1.6"
	},
	"autoload-dev": {
		"psr-4": {
			"Lessly\\Tests\\": "tests/unit/"
		}
	},
	"scripts": {
		"php:lint": "vendor/bin/phpcs -p -s",
		"php:lint:errors": "vendor/bin/phpcs -p -s --runtime-set ignore_warnings_on_exit 1",
		"php:lint:autofix": "vendor/bin/phpcbf",
		"php:lint:changed": "@php scripts/lint-changed.php",
		"test": "vendor/bin/phpunit",
		"test:unit": "vendor/bin/phpunit --testsuite unit",
		"test:coverage": "vendor/bin/phpunit --coverage-html tests/coverage",
		"test:filter": "vendor/bin/phpunit --filter",
		"make-pot": "wp i18n make-pot . lessly/languages/lessly.pot"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}